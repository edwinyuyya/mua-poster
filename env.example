# Supabase - ambil dari supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxx

# Service role key (opsional, untuk operasi tulis di server). Jika kosong,
# server pakai anon key. JANGAN pernah expose key ini ke client.
SUPABASE_SERVICE_ROLE_KEY=

# PIN akses per peran. Server-only (tanpa NEXT_PUBLIC) -> tidak bocor ke browser.
# STAFF_PIN = fallback: dipakai jika PIN peran di bawah dikosongkan.
# Kosongkan semua = tanpa PIN. Isi PIN peran berbeda-beda untuk pisahkan akses.
STAFF_PIN=1234
OWNER_PIN=2468     # Dashboard Owner
ADMIN_PIN=         # Admin (kelola meja/menu/harga) - kosong = pakai STAFF_PIN
KASIR_PIN=         # Kasir (konfirmasi bayar, void) - kosong = pakai STAFF_PIN
DAPUR_PIN=         # Dapur / Kitchen display - kosong = pakai STAFF_PIN
STOK_PIN=          # Gudang / Stok & belanja - kosong = pakai STAFF_PIN

# Alert stok mendekati kadaluarsa
ALERT_EXPIRY_DAYS=3
# --- Notifikasi WhatsApp (opsional) ---
# Cara 1 (REKOMENDASI): gateway Fonnte (https://fonnte.com) - murah & populer di ID.
#   Daftar -> sambungkan WA -> salin token perangkat ke FONNTE_TOKEN.
#   WA_TARGET = nomor tujuan (mis. 6281234567890). Boleh banyak, pisah koma.
FONNTE_TOKEN=
WA_TARGET=
# Cara 2: webhook umum (Slack/Discord/Telegram-gateway). Dipakai bila Fonnte kosong.
ALERT_WEBHOOK_URL=
# Rahasia untuk mengamankan endpoint cron (Vercel mengirimkannya otomatis)
CRON_SECRET=rahasia_cron_bebas

# Base URL aplikasi (untuk generate link QR meja). Contoh: https://restoran.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Info merchant untuk QRIS / struk
NEXT_PUBLIC_MERCHANT_NAME=BBQIU Grill, Suki & Eatery
NEXT_PUBLIC_TAX_PERCENT=10

# Payload statis QRIS merchant. Jika diisi, halaman bayar menampilkan QRIS yang
# nominalnya OTOMATIS terisi sesuai total (dinamis, CRC dihitung ulang).
# Nilai di bawah = QRIS BBQIU (hasil baca dari QR cetak merchant).
NEXT_PUBLIC_QRIS_STATIC=00020101021126650013ID.CO.BCA.WWW011893600014000146145102150008850014614510303UKE51440014ID.CO.QRIS.WWW0215ID10211418353680303UKE5204581253033605802ID5918BBQIU FUSION GRILL6004SOLO61055714262070703A0163048456
